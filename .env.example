# Copy to .env for local development:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (macOS/Linux)
#
# .env is gitignored — never commit real secrets.

# Flask CLI entry point (optional; default: flask --app app run)
FLASK_APP=app

# Enable debug mode locally (do not use in production)
FLASK_DEBUG=1

# Session signing key — required before production; use a random value locally
SECRET_KEY=change-me-to-a-random-secret
